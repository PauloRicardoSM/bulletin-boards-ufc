* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    --yellow: #FFE600;
    --yellow-soft: #FFEC33;
    --black: #1a1a1a;
    --white: #ffffff;
    --blue: #2563eb;
    --blue-dark: #1d4ed8;
    --border: 2px solid #1a1a1a;
    --thick-border: 3px solid #1a1a1a;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    background-color: var(--yellow);
    color: var(--black);
    min-height: 100vh;
    padding: 24px 48px;
}

/* HEADER */
.header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 32px;
    gap: 24px;
}

.logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    font-size: 18px;
}

.logo-icon {
    width: 22px;
    height: 22px;
    border: var(--border);
    border-radius: 4px;
    background-color: var(--white);
    position: relative;
}

.logo-icon::before {
    content: "";
    position: absolute;
    top: 4px;
    left: 4px;
    right: 4px;
    height: 2px;
    background: var(--black);
    box-shadow: 0 5px 0 var(--black), 0 10px 0 var(--black);
}

.logo-text {
    letter-spacing: 0.2px;
}

.nav {
    display: flex;
    gap: 36px;
    flex: 1;
    justify-content: center;
}

.nav-link {
    text-decoration: none;
    color: var(--black);
    font-weight: 500;
    font-size: 15px;
    padding: 4px 2px;
    transition: opacity 0.15s ease;
}

.nav-link:hover {
    opacity: 0.65;
}

.nav-link.active {
    font-weight: 700;
}

.btn-cta {
    background-color: var(--blue);
    border: var(--border);
    border-radius: 24px;
    padding: 8px 20px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.1s ease, box-shadow 0.1s ease, background-color 0.15s ease;
    color: var(--white);
}

.btn-cta:hover {
    background-color: var(--blue-dark);
    transform: translate(-1px, -1px);
    box-shadow: 2px 2px 0 var(--black);
}

/* MAIN */
.main {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 32px;
    align-items: start;
}

/* TOOLBAR */
.toolbar {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
}

.search-wrapper {
    flex: 1;
    position: relative;
    max-width: 520px;
}

.search-input {
    width: 100%;
    background-color: var(--yellow-soft);
    border: var(--border);
    border-radius: 24px;
    padding: 10px 18px 10px 18px;
    font-size: 14px;
    outline: none;
    color: var(--black);
}

.search-input::placeholder {
    color: var(--black);
    opacity: 0.55;
}

.search-input:focus {
    background-color: var(--white);
}

.search-icon {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 18px;
    pointer-events: none;
}

.filters {
    display: flex;
    gap: 10px;
    margin-left: auto;
}

.filter-btn {
    background-color: var(--white);
    border: var(--border);
    border-radius: 20px;
    padding: 8px 22px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    color: var(--black);
    transition: all 0.15s ease;
}

.filter-btn:hover {
    background-color: var(--yellow-soft);
}

.filter-btn.active {
    background-color: var(--black);
    color: var(--white);
}

/* CARDS GRID */
.cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 32px;
}

.card {
    background-color: var(--white);
    border: var(--border);
    border-radius: 8px;
    padding: 18px;
    display: flex;
    flex-direction: column;
    min-height: 240px;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--black);
}

.card-title {
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 10px;
    line-height: 1.3;
}

.card-author {
    font-size: 11px;
    color: #555;
    margin-bottom: 12px;
}

.card-description {
    font-size: 12px;
    line-height: 1.5;
    color: #333;
    flex: 1;
    margin-bottom: 14px;
}

.card-actions {
    display: flex;
    align-items: center;
    gap: 18px;
    padding-top: 12px;
    border-top: 1px solid #e5e5e5;
}

.card-action {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 13px;
    color: var(--black);
    padding: 0;
    transition: opacity 0.15s ease;
}

.card-action:hover {
    opacity: 0.6;
}

.card-action.liked {
    color: #d97706;
}

.icon {
    width: 18px;
    height: 18px;
    display: inline-block;
}

/* PAGINATION */
.pagination {
    display: flex;
    justify-content: center;
    margin-top: 8px;
}

.btn-pagination {
    background-color: var(--white);
    border: var(--border);
    border-radius: 22px;
    padding: 10px 28px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    color: var(--black);
    transition: all 0.15s ease;
}

.btn-pagination:hover {
    background-color: var(--black);
    color: var(--white);
}

/* SIDEBAR */
.sidebar {
    position: sticky;
    top: 24px;
}

.share-card {
    background-color: var(--white);
    border: var(--border);
    border-radius: 10px;
    padding: 22px 20px;
}

.share-title {
    font-size: 14px;
    font-weight: 700;
    margin-bottom: 14px;
    line-height: 1.35;
}

.share-list {
    list-style: none;
    margin-bottom: 20px;
}

.share-list li {
    font-size: 12px;
    line-height: 1.5;
    color: #333;
    padding-left: 14px;
    position: relative;
    margin-bottom: 8px;
}

.share-list li::before {
    content: "•";
    position: absolute;
    left: 0;
    top: 0;
    font-weight: 700;
}

.btn-publish {
    width: 100%;
    background-color: var(--blue);
    border: var(--border);
    border-radius: 22px;
    padding: 10px 16px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    color: var(--white);
    transition: all 0.15s ease;
}

.btn-publish:hover {
    background-color: var(--blue-dark);
    transform: translate(-1px, -1px);
    box-shadow: 2px 2px 0 var(--black);
}

/* RESPONSIVO */
@media (max-width: 1024px) {
    .main {
        grid-template-columns: 1fr;
    }
    .sidebar {
        position: static;
    }
    .cards-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 720px) {
    body {
        padding: 16px;
    }
    .header {
        flex-wrap: wrap;
    }
    .nav {
        order: 3;
        width: 100%;
        justify-content: flex-start;
        gap: 18px;
    }
    .toolbar {
        flex-direction: column;
        align-items: stretch;
    }
    .filters {
        margin-left: 0;
    }
    .cards-grid {
        grid-template-columns: 1fr;
    }
}
